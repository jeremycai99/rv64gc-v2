{
  "goal_contract": {
    "name": "stage1",
    "version": "stage1-2026-05-06-v2",
    "scoreable_with": "tools/run_benchmarks.py --goal stage1 --run-class signoff"
  },
  "notes": "Stage 1 long-run signoff manifest. DS/CoreMark remain anchor rows, and the added frontend/backend/memory/hotspot rows are generalization guards so Stage 1 does not overfit the anchors. These rows are scoreable only under tools/run_benchmarks.py --run-class signoff, with endpoint identity intact, legacy loop-buffer activity zero, canonical standalone decoded-op replay telemetry present and zero, and no standalone UOC, same-tail, or local lookahead replay plusargs. counter_invariants are checked on every run_class (signoff and dse); counter_targets_stage1 are checked only on signoff. SPEC/Embench/MiBench images are not checked into this repo; add them as separate local manifests when built.",
  "schema_extensions": {
    "counter_invariants": "Per-counter {min,max} bounds that MUST hold on every run regardless of class. Use to lock in structural invariants (e.g. owner-identity counters that must remain zero post-FTQ-split).",
    "counter_targets_stage1": "Per-counter {min,max} bounds enforced only when --run-class signoff. Use to encode Stage 1 acceptance gates beyond flags+checksum so the doc-level pass condition is machine-checkable.",
    "golden_pc_path": "Optional. Path to a $readmemh-format file of expected commit PCs (one 16-hex-digit PC per line). When present and run_benchmarks.py forwards +CHECK_GOLDEN_PCS, the testbench asserts every retired PC matches the golden stream and finishes with [GOLDEN_PC TRIP] on first divergence.",
    "suite": "Optional. Human-readable grouping for broader signoff coverage; the runner records it in manifests but does not change gate behavior."
  },
